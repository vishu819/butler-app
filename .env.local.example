# Copy to .env.local and fill in. NEVER commit .env.local.

# Supabase — Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://eqhflowsnjzewfvlwkto.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# service_role key (secret — server only). Project Settings > API > service_role
SUPABASE_SERVICE_ROLE_KEY=xxx

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxx
# Default model for all roles. See https://openrouter.ai/models
OPENROUTER_MODEL=google/gemini-2.5-flash

# Optional per-role model overrides (model-agnostic config, lib/models.ts).
# Leave unset to use OPENROUTER_MODEL for everything. A sharper model for
# JUDGE (grading/progression) is often worth it.
# OPENROUTER_MODEL_JUDGE=anthropic/claude-3.5-sonnet
# OPENROUTER_MODEL_GENERATE=google/gemini-2.5-flash
# OPENROUTER_MODEL_WEB=google/gemini-2.5-flash
# OPENROUTER_MODEL_COACH=google/gemini-2.5-flash

# Random string to protect the cron endpoint. e.g. `openssl rand -hex 16`
CRON_SECRET=change-me
