# Copy to .env.local and fill in. NEVER commit .env.local.

# Supabase — Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://eqhflowsnjzewfvlwkto.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# service_role key (secret — server only). Project Settings > API > service_role
SUPABASE_SERVICE_ROLE_KEY=xxx

# OpenRouter — https://openrouter.ai/keys  (ROTATE the one you pasted in chat)
OPENROUTER_API_KEY=sk-or-v1-xxx
# Which model the coach uses. See https://openrouter.ai/models
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Random string to protect the cron endpoint. e.g. `openssl rand -hex 16`
CRON_SECRET=change-me
